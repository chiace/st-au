{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "metadata": {
    "name": "Superteam Australia Design Tokens",
    "version": "1.0.0",
    "source": "src/design-system/tokens.ts",
    "note": "Keep in sync with tokens.ts for tooling and Figma plugins; TypeScript remains canonical for the app build."
  },
  "colors": {
    "ink": "#07101F",
    "inkSoft": "#08162B",
    "green": "#00833E",
    "greenSoft": "#22A35A",
    "gold": "#FECE00",
    "goldSoft": "#FFE066",
    "azure": "#6FD3FF",
    "violet": "#7B6DFF",
    "textPrimary": "#0F172A",
    "textSecondary": "#475569",
    "surfaceLight": "#F8FAFC",
    "surfaceLightWarm": "#FBF5E7",
    "white": "#FFFFFF"
  },
  "gradients": {
    "brandAurora": "linear-gradient(135deg,#07101F 0%,#112216 34%,#00833E 78%,#FECE00 140%)",
    "primaryCta": "linear-gradient(135deg,#0f7d43 0%,#00833E 44%,#22a35a 72%,#FECE00 100%)",
    "supportPanel": "linear-gradient(115deg,rgba(112,156,58,0.98) 0%,rgba(64,132,62,0.97) 28%,rgba(184,179,63,0.94) 64%,rgba(247,198,58,0.92) 100%)",
    "darkCard": "linear-gradient(180deg,rgba(8,14,24,0.96),rgba(7,11,20,0.94))"
  },
  "layout": {
    "containerMax": "1320px",
    "contentNarrow": "920px",
    "contentSplit": "980px",
    "modalWide": "900px",
    "headerCompact": "420px"
  },
  "radii": {
    "pill": "999px",
    "small": "0.875rem",
    "medium": "1rem",
    "large": "1.5rem",
    "xl": "1.75rem",
    "hero": "2.375rem"
  },
  "shadows": {
    "subtle": "0 10px 28px rgba(7, 18, 45, 0.04)",
    "card": "0 16px 40px rgba(8, 17, 39, 0.05)",
    "panel": "0 24px 70px rgba(3, 8, 18, 0.18)",
    "modal": "0 20px 50px rgba(15, 23, 42, 0.12)"
  },
  "motion": {
    "durations": { "fast": "180ms", "base": "240ms", "slow": "700ms" },
    "easing": {
      "standardCss": "cubic-bezier(0.22, 1, 0.36, 1)",
      "standardBezier": [0.22, 1, 0.36, 1],
      "emphasis": "ease-in-out",
      "linear": "linear"
    }
  },
  "breakpoints": {
    "sm": "640px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "zIndex": {
    "base": 0,
    "header": 50,
    "modal": 80
  }
}
